# Example environment variables for KGI System
# Copy to .env and fill in real values before running services.

# Gemini API key for RAG service
GENAI_API_KEY=your_gemini_api_key

# Qdrant vector database settings
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=kfh_docs_gemini

# Microservice URLs used by the gateway
MKT_URL=http://market:8001
RAG_URL=http://rag:8002
ADV_URL=http://advisor:8003
RPT_URL=http://report:8004
GATEWAY_URL=http://localhost:8000

# Redis cache for market service
REDIS_HOST=redis
REDIS_PORT=6379
MARKET_TTL_SEC=90
