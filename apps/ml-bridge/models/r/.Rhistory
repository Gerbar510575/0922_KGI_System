library(ggplot2)
library(sf)
library(rnaturalearth)
library(rnaturalearthdata)
world <- ne_countries(scale = "medium", returnclass = "sf")
# 對齊名稱（示範調整幾個）
tariff_data$country[tariff_data$country == "CÔTE D`IVOIRE"] <- "Ivory Coast"
tariff_data$country[tariff_data$country == "DEM. REP. OF THE CONGO"] <- "Democratic Republic of the Congo"
tariff_data$country[tariff_data$country == "UNITED KINGDOM"] <- "United Kingdom"
tariff_data$country[tariff_data$country == "UNITED STATES"] <- "United States of America"  # 若有
tariff_data$country[tariff_data$country == "EUROPEAN UNION*"] <- "European Union"
tariff_data$country[tariff_data$country == "EUROPEAN UNION**"] <- "European Union"
# 合併
map_data <- left_join(world, tariff_data, by = c("name" = "country"))
ggplot(data = map_data) +
geom_sf(aes(fill = tariff_avg)) +
scale_fill_viridis_c(option = "plasma", na.value = "lightgrey", name = "平均關稅 (%)") +
geom_sf_text(aes(label = ifelse(!is.na(tariff_avg), paste0(round(tariff_avg), "%"), "")), size = 2.5, color = "black") +
theme_minimal() +
labs(title = "世界各國平均關稅", subtitle = "資料來源：人工彙整", caption = "未提供者顯示為灰色")
View(tariff_data)
View(world)
