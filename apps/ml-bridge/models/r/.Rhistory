# --- 套件 ---
library(tidyverse)
library(lubridate)
library(tidymodels)
library(themis)       # for SMOTE
library(vip)          # feature importance
set.seed(123)
library(plm)
library(broom)
library(dplyr)
library(ggplot2)
library(purrr)
library(haven)
library(scales)
library(data.table)
library(stringr)
library(fastDummies)
library(tidyr)
library(gridExtra)
library(nlme)
library(DT)
library(writexl)
library(yardstick)
library(knitr)
library(kableExtra)
# =========================
# 1) 讀取資料（優先使用 train.csv）
# =========================
# 放在與此 R 檔相同資料夾時，直接 read_csv("train.csv")
# 若需指定路徑，可改成 read_csv("你的路徑/train.csv")
df_raw <- read_csv("train.csv", guess_max = 1e5)
View(df_raw)
# =========================
# 2) 目標欄位與面板欄位自動偵測
# =========================
# 若已存在「危機」則沿用；若存在 Loan_Status (Y/N)，轉成 危機(0/1)
if (!("危機" %in% names(df_raw))) {
if ("Loan_Status" %in% names(df_raw)) {
df_raw <- df_raw %>%
mutate(
危機 = if_else(Loan_Status %in% c("Y","y","1",1), 1L, 0L)
)
# 避免洩漏，轉完就移除 Loan_Status
df_raw <- df_raw %>% select(-Loan_Status)
} else {
stop("找不到目標欄位：既沒有『危機』也沒有『Loan_Status』可轉換。請提供其中之一。")
}
}
# 將目標變數設為 factor(c("0","1"))，確保 .pred_1 會被產出
df_raw <- df_raw %>%
mutate(危機 = factor(危機, levels = c(0,1), labels = c("0","1")))
View(df_raw)
# 面板偵測：同時有「公司」與「年月」才算面板
IS_PANEL <- all(c("公司","年月") %in% names(df_raw))
# =========================
# 3) 面板資料處理（若為面板）
# =========================
if (IS_PANEL) {
# 嘗試把「年月」轉成 Date
if (!inherits(df_raw$年月, "Date")) {
df_raw <- df_raw %>%
mutate(年月 = suppressWarnings(as.Date(年月)))
}
# 只保留 2006~2010，每家公司五個年份都完整
df_panel <- df_raw %>%
mutate(year = year(年月)) %>%
filter(!is.na(year), year >= 2006, year <= 2010) %>%
group_by(公司) %>%
filter(n_distinct(year) == 5) %>%
ungroup()
if (nrow(df_panel) == 0) {
warning("面板條件（2006–2010、每公司五年皆有）過於嚴格，改為不篩年份的全資料。")
df_panel <- df_raw %>% mutate(year = if ("年月" %in% names(.)) year(年月) else NA_integer_)
}
} else {
# 非面板：直接用全資料，補上 year 欄位為 NA（以便後續統一欄位）
df_panel <- df_raw %>% mutate(year = NA_integer_)
}
View(df_raw)
# 4) 移除高度缺失的欄位（>30%）
# =========================
na_ratio <- sapply(df_panel, function(x) mean(is.na(x)))
drop_high_na <- names(na_ratio[na_ratio > 0.30])
drop_high_na <- setdiff(drop_high_na, c(id_cols, target))
if (IS_PANEL) {
# 依「公司」做群組切分，避免洩漏
companies <- unique(df_model0$公司)
set.seed(123)
test_companies <- sample(companies, size = max(1, round(0.2 * length(companies))))
train_companies <- setdiff(companies, test_companies)
train_df <- df_model0 %>% filter(公司 %in% train_companies)
test_df  <- df_model0 %>% filter(公司 %in% test_companies)
} else {
# 一般分類：用 rsample 的 initial_split，並以目標變數分層
set.seed(123)
split <- initial_split(df_model0, prop = 0.8, strata = !!sym(target))
train_df <- training(split)
test_df  <- testing(split)
}
# 產業別如果存在就轉因子
if ("TEJ 產業別" %in% names(df_panel)) {
df_panel <- df_panel %>% mutate(`TEJ 產業別` = as.factor(`TEJ 產業別`))
}
# 確保目標為 factor("0","1")（已在上面轉好）
id_cols <- intersect(c("公司", "年月", "year"), names(df_panel))
target  <- "危機"
# =========================
# 4) 移除高度缺失的欄位（>30%）
# =========================
na_ratio <- sapply(df_panel, function(x) mean(is.na(x)))
drop_high_na <- names(na_ratio[na_ratio > 0.30])
drop_high_na <- setdiff(drop_high_na, c(id_cols, target))
df_model0 <- df_panel %>% select(-all_of(drop_high_na))
# =========================
# 5) 訓練 / 測試切分
# =========================
if (IS_PANEL) {
# 依「公司」做群組切分，避免洩漏
companies <- unique(df_model0$公司)
set.seed(123)
test_companies <- sample(companies, size = max(1, round(0.2 * length(companies))))
train_companies <- setdiff(companies, test_companies)
train_df <- df_model0 %>% filter(公司 %in% train_companies)
test_df  <- df_model0 %>% filter(公司 %in% test_companies)
} else {
# 一般分類：用 rsample 的 initial_split，並以目標變數分層
set.seed(123)
split <- initial_split(df_model0, prop = 0.8, strata = !!sym(target))
train_df <- training(split)
test_df  <- testing(split)
}
stopifnot(nrow(train_df) > 0, nrow(test_df) > 0)
# =========================
# 6) 建立配方（前處理 + SMOTE）
# =========================
rec <- recipe(as.formula(paste(target, "~ .")), data = train_df) %>%
update_role(all_of(id_cols), new_role = "ID") %>%
step_zv(all_predictors()) %>%
step_nzv(all_predictors()) %>%
step_string2factor(all_nominal_predictors()) %>%
step_novel(all_nominal_predictors()) %>%
step_other(all_nominal_predictors(), threshold = 0.01) %>%
step_dummy(all_nominal_predictors()) %>%
step_impute_median(all_numeric_predictors()) %>%
step_normalize(all_numeric_predictors()) %>%
step_corr(all_numeric_predictors(), threshold = 0.95) %>%
step_smote(all_outcomes(), neighbors = 5)
# =========================
# 7) LASSO 模型與 workflow
# =========================
lasso_spec <- logistic_reg(
penalty = tune(),   # 調整 L1 懲罰係數 λ
mixture = 1
) %>% set_engine("glmnet") %>% set_mode("classification")
wf <- workflow() %>% add_model(lasso_spec) %>% add_recipe(rec)
# =========================
# 8) 交叉驗證設定
# =========================
if (IS_PANEL) {
cv_folds <- group_vfold_cv(train_df, group = 公司, v = 5)
} else {
cv_folds <- vfold_cv(train_df, v = 5, strata = !!sym(target))
}
grid <- grid_regular(penalty(), levels = 40)
metrics_set <- metric_set(roc_auc, accuracy, sens, spec, f_meas)
tuned <- tune_grid(
wf,
resamples = cv_folds,
grid = grid,
metrics = metrics_set,
control = control_grid(save_pred = TRUE)
)
best <- select_best(tuned, metric = "roc_auc")
final_wf <- finalize_workflow(wf, best)
final_fit <- fit(final_wf, data = train_df)
# =========================
# 9) 測試集預測（機率）
# =========================
test_probs <- predict(final_fit, test_df, type = "prob") %>%
bind_cols(test_df %>% select(!!sym(target)))
View(test_probs)
head(df_raw)
